# FoldOps agent — copy to /etc/foldops/agent.env and set secrets.
# AGENT_TOKEN must match supervisor INGEST_TOKEN.

SUPERVISOR_URL=http://fah-01:3000
AGENT_TOKEN=change-me-to-a-long-random-secret
INTERVAL_MS=60000

FAH_LOG_PATH=/var/log/fah-client/log.txt
FAH_WS_HOST=127.0.0.1
FAH_WS_PORT=7396
FAH_DB_PATH=/var/lib/fah-client/client.db
FAH_WORK_DIR=/var/lib/fah-client/work

# Supervisor live log pull + deploy (port must match supervisor AGENT_HTTP_PORT)
AGENT_HTTP_PORT=9100

# Folding-OS images: remote git/npm update is disabled (no FOLDOPS_ROOT on appliance).
# UPDATE_ENABLED is for legacy Debian git-checkout farms only.

# Remote control from supervisor dashboard
# CONTROLS_ENABLED=true
# CONTROLS_ALLOW_REBOOT=true
