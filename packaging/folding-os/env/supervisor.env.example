# FoldOps supervisor — copy to /etc/foldops/supervisor.env and set secrets.

HOST=0.0.0.0
PORT=3000
INGEST_TOKEN=change-me-to-a-long-random-secret
DB_PATH=/var/lib/foldops/foldops.db
WEB_ROOT=/usr/share/foldops/web
OFFLINE_THRESHOLD_MS=120000

# Alerts — see docs/alerts.md
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERTS_ENABLED=true
# ALERT_DASHBOARD_URL=http://fah-01:3000
# ALERT_DISCORD_USERNAME=FoldOps
# CPU_TEMP_ALERT_C=85
# ALERT_STUCK_HOURS=4

# Live log pull + agent proxy (must match AGENT_HTTP_PORT on each node)
AGENT_HTTP_PORT=9100

# Legacy Debian/git-checkout farms only — not used on Folding-OS appliances
# DEPLOY_ENABLED=true
# CONTROL_ENABLED=true
