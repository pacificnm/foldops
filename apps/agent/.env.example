# Supervisor URL — must be reachable from this node (e.g. http://192.168.4.10:3000)
SUPERVISOR_URL=http://192.168.4.10:3000
AGENT_TOKEN=change-me-to-a-long-random-secret
INTERVAL_MS=60000
FAH_LOG_PATH=/var/log/fah-client/log.txt
# FAH v8 local API (PPD/TPF during CORE before client.db updates)
FAH_WS_HOST=127.0.0.1
FAH_WS_PORT=7396
FAH_DB_PATH=/var/lib/fah-client/client.db
FAH_WORK_DIR=/var/lib/fah-client/work
# HTTP API for live log pull from supervisor (port 9100; set 0 to disable)
AGENT_HTTP_PORT=9100
# Remote updates from supervisor (git pull + build + restart)
# UPDATE_ENABLED=true
# FOLDOPS_ROOT=/opt/foldops
