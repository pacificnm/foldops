# Supervisor URL — must be reachable from this node (e.g. http://192.168.4.10:3000)
SUPERVISOR_URL=http://192.168.4.10:3000
AGENT_TOKEN=change-me-to-a-long-random-secret
INTERVAL_MS=60000
FAH_LOG_PATH=/var/log/fah-client/log.txt
FAH_DB_PATH=/var/lib/fah-client/client.db
FAH_WORK_DIR=/var/lib/fah-client/work
