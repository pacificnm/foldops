PORT=3000
# Listen on all interfaces so farm agents can reach this host (required for LAN nodes)
HOST=0.0.0.0
DB_PATH=./data/foldops.db
INGEST_TOKEN=change-me-to-a-long-random-secret
OFFLINE_THRESHOLD_MS=120000

# Alerts — see docs/alerts.md for Discord setup
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERTS_ENABLED=true
# ALERT_DASHBOARD_URL=http://192.168.4.10:3000
# ALERT_DISCORD_USERNAME=FoldOps
# CPU_TEMP_ALERT_C=85

# Live log pull from agents (must match AGENT_HTTP_PORT on each node)
# AGENT_HTTP_PORT=9100

# Push agent updates to farm nodes from the dashboard
# DEPLOY_ENABLED=true

# Remote control tab on machine detail (start/stop FAH, agent, reboot)
# CONTROL_ENABLED=true
