PORT=3000
# Listen on all interfaces so farm agents can reach this host (required for LAN nodes)
HOST=0.0.0.0
DB_PATH=./data/foldops.db
INGEST_TOKEN=change-me-to-a-long-random-secret
OFFLINE_THRESHOLD_MS=120000

# Alerts (optional) — Discord/Slack incoming webhook URL
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERTS_ENABLED=true
# CPU_TEMP_ALERT_C=85

# Live log pull from agents (must match AGENT_HTTP_PORT on each node)
# AGENT_HTTP_PORT=9100
