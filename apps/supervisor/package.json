{
  "name": "@foldops/supervisor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build -w @foldops/shared && tsc && npm run build:web",
    "build:web": "npm run build --prefix web",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:web": "npm run dev --prefix web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@foldops/shared": "*",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
