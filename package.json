{
  "name": "foldops",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Folding@home farm monitor",
  "workspaces": [
    "apps/*",
    "apps/supervisor/web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w @foldops/shared",
    "build:agent": "npm run build -w @foldops/shared && npm run build -w @foldops/agent",
    "build:web": "npm run build -w @foldops/web",
    "build:supervisor": "npm run build -w @foldops/shared && npm run build -w @foldops/supervisor && npm run build -w @foldops/web",
    "typecheck": "npm run build -w @foldops/shared && npm run typecheck -w @foldops/shared && npm run typecheck -w @foldops/agent && npm run typecheck -w @foldops/supervisor && npm run typecheck -w @foldops/web",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "dev:supervisor": "npm run dev -w @foldops/supervisor",
    "dev:agent": "npm run dev -w @foldops/agent",
    "start:supervisor": "npm run start -w @foldops/supervisor",
    "start:agent": "npm run start -w @foldops/agent",
    "build:rust": "cargo build --release --workspace",
    "build:rust:agent": "cargo build --release -p foldops-agent",
    "build:rust:supervisor": "cargo build --release -p foldops-supervisor",
    "test:rust": "cargo test --workspace",
    "check:rust": "cargo fmt --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace",
    "check:rust-prereqs": "./scripts/check-rust-prereqs.sh",
    "vendor:rust": "./scripts/vendor-rust-deps.sh",
    "build:folding-os": "./scripts/build-folding-os-artifacts.sh",
    "build:debs": "./scripts/build-debs.sh",
    "build:apt-repo": "./scripts/build-apt-repo.sh"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5"
  }
}
